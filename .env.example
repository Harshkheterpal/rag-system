PINECONE_INDEX_NAME=rag-system

# Application Settings
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
"@ | Out-File -Encoding UTF8 ".env.example"